<?xml version="1.0" encoding="utf-8"?>
<!--
    네트워크 보안 설정 — HTTPS only (cleartext HTTP 비허용)
    예외: debug 빌드에서 localhost 허용 (개발 편의)
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- 개발 빌드에서만 localhost 허용 -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
